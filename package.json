{
  "name": "poc-tile-editor-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tile pipeline monorepo: editor (tool) + game (runtime) + shared core, joined by bundles.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @poc/editor",
    "dev:editor": "npm run dev -w @poc/editor",
    "build": "npm run build -w @poc/editor",
    "build:editor": "npm run build -w @poc/editor",
    "preview": "npm run preview -w @poc/editor",
    "bundle:demo": "node tools/make-demo-bundle.mjs",
    "tileset:sample": "node tools/make-sample-tileset.js"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
